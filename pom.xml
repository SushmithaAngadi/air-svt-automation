            </releases>
        </repository>

        <repository>
            <id>jfrog-bfcom-stable</id>
            <name>JFrog BFCom Stable</name>
            <url>https://artifactory.softwaretools.resideo.com/artifactory/bfcom-maven-stable-local</url>
            <snapshots>
                <enabled>false</enabled>
            </snapshots>
            <releases>
                <enabled>true</enabled>
                <updatePolicy>always</updatePolicy>
            </releases>
        </repository>

