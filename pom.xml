            <id>jfrog-releases</id>
            <name>JFrog Releases</name>
            <url>https://artifactory.softwaretools.resideo.com/artifactory/libs-release</url>
            <snapshots>
                <enabled>false</enabled>
            </snapshots>
            <releases>
